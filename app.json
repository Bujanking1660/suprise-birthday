{
  "expo": {
    "name": "HBD Rasya",
    "slug": "birtday205thrasya",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF4E0"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan QR codes to unlock birthday surprises!"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF4E0"
      },
      "package": "com.rizkyagusnaldykaliaa.birtday205thrasya",
      "versionCode": 5,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to scan QR codes for birthday surprises!"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to save wallpapers to your gallery.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save wallpapers to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "ff1800b1-09b5-48be-a135-22c702ca81ee"
      }
    }
  }
}
